# URL deployment Google Apps Script yang berakhiran /exec
GAS_WEB_APP_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec

# Secret 64 karakter hex. Nilai harus sama dengan Script Property API_SHARED_SECRET.
API_SHARED_SECRET=ganti_dengan_secret_64_karakter

# Pisahkan beberapa origin dengan koma. Isi URL Netlify dan custom domain.
ALLOWED_ORIGINS=https://nama-situs.netlify.app,https://perpus.domain.go.id


